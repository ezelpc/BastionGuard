{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug test-executor",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/ts-node/dist/bin.js",
      "args": [
        "--project",
        "${workspaceFolder}/tsconfig.json",
        "${workspaceFolder}/src/test-executor.ts"
      ],
      "cwd": "${workspaceFolder}",
      "protocol": "inspector",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "development",
        "DEBUG": "bastionguard:*",
        "DRY_RUN": "true"
      }
    },
    {
      "name": "Attach to Process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
