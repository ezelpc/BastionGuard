{
  "name": "bastionguard",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node src/test-executor.ts",
    "dev:mock": "AI_MOCK=true ts-node src/test-executor.ts",
    "dev:watch": "nodemon --exec ts-node src/test-executor.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' && prettier --write 'src/**/*.json'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist && rm -rf node_modules && npm cache clean --force"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.93.0",
    "@aws-sdk/client-ecs": "^3.600.0",
    "@kubernetes/client-node": "^1.4.0",
    "dockerode": "^4.0.2",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "twilio": "^4.20.0",
    "typescript": "^6.0.3",
    "yaml": "^2.4.2"
  },
  "devDependencies": {
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.0",
    "@types/socket.io": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1"
  }
