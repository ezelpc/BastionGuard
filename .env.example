# Development Environment Configuration

# Node
NODE_ENV=development
DEBUG=bastionguard:*
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USER=bastionguard
DB_PASSWORD=dev-password
DB_NAME=bastionguard_dev

# Cache (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Kubernetes
KUBECONFIG=${HOME}/.kube/config

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# API Server
API_PORT=3000
API_HOST=0.0.0.0

# Monitoring
PROMETHEUS_ENABLED=false
METRICS_PORT=9090

# Security
JWT_SECRET=dev-secret-key-change-in-production
DRY_RUN=true

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=

# Feature Flags
ENABLE_AUDIT_LOG=true
ENABLE_AUDIT_LOG_PERSISTENCE=false
